# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/storepilot?schema=public"

# NextAuth secret - generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Public app URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (server-side only, never exposed to frontend or extension)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (create recurring monthly prices in the Stripe Dashboard)
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_BUSINESS="price_..."
STRIPE_PRICE_PRO="price_..."
