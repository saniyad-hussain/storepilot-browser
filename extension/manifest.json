{
  "manifest_version": 3,
  "name": "StorePilot Access Hub",
  "version": "1.0.0",
  "description": "A safer browser workspace for your store team - quick links, reply templates, and support requests. Does not store passwords.",
  "permissions": ["storage", "tabs"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "StorePilot Access Hub",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
